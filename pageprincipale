<ul>
<li>1 : tonalité de la voix</li>
<li>2 : volume</li>
<li>3 : vitesse</li>
<li>11 : éjecter CD</li>
<li>12 : allumer / éteindre</li>
<li>13 : recul rapide</li>
<li>14 : lecture / pause / stop</li>
<li>15 : avance rapide</li>
<li>16 : mise en veille</li>
<li>17 : lecteur carte SD</li>
<li>18 : port USB</li>
<li>19 : prise casque</li>
<li>20 : alimentation</li>
<li>21 : insertion CD Daisy</li>
</ul>
</div>
</section>

